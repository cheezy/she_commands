<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="She Commands" suffix=" · She Doesn't Ask. She Commands.">
      {assigns[:page_title]}
    </.live_title>
    <link
      href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;700&family=Space+Grotesk:wght@400;500;700&family=Work+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    <header class="absolute top-0 left-0 w-full z-50 bg-transparent text-white">
      <nav class="container mx-auto px-6 py-4 flex flex-col items-center">
        <a href="/" class="flex items-center gap-2 mb-4">
          <img
            src={~p"/images/she_commands_logo.webp"}
            alt="She Commands"
            class="h-14"
          />
        </a>
        <div class="flex justify-between w-full items-center">
          <div class="flex gap-8 mx-auto text-[0.75rem] uppercase tracking-[0.05em] font-medium">
            <a
              href="/brand"
              class={"hover:opacity-70 transition #{if @conn.request_path == "/brand", do: "border-b border-white pb-1"}"}
            >
              {gettext("The Brand")}
            </a>
            <a
              href="/goal-execution"
              class={"hover:opacity-70 transition #{if @conn.request_path == "/goal-execution", do: "border-b border-white pb-1"}"}
            >
              {gettext("Goal Execution")}
            </a>
            <a
              href="/experiences"
              class={"hover:opacity-70 transition #{if @conn.request_path == "/experiences", do: "border-b border-white pb-1"}"}
            >
              {gettext("Experiences")}
            </a>
            <a
              href="/connect"
              class={"hover:opacity-70 transition #{if @conn.request_path == "/connect", do: "border-b border-white pb-1"}"}
            >
              {gettext("Connect")}
            </a>
            <a
              href="/the-journal"
              class={"hover:opacity-70 transition #{if @conn.request_path == "/the-journal", do: "border-b border-white pb-1"}"}
            >
              {gettext("The Journal")}
            </a>
            <%= if @current_scope do %>
              <details class="dropdown dropdown-end relative">
                <summary class="cursor-pointer hover:opacity-70 transition">
                  {@current_scope.user.name || @current_scope.user.email}
                </summary>
                <ul class="dropdown-content menu bg-base-200 text-base-content rounded-box z-50 w-52 p-2 shadow-lg mt-2">
                  <li>
                    <.link href={~p"/users/settings"}>{gettext("Settings")}</.link>
                  </li>
                  <li>
                    <.link href={~p"/users/log-out"} method="delete">
                      {gettext("Log out")}
                    </.link>
                  </li>
                </ul>
              </details>
            <% else %>
              <.link href={~p"/users/register"} class="hover:opacity-70 transition">
                {gettext("Register")}
              </.link>
              <.link href={~p"/users/log-in"} class="hover:opacity-70 transition">
                {gettext("Log in")}
              </.link>
            <% end %>
          </div>
        </div>
      </nav>
    </header>
    {@inner_content}
  </body>
</html>
